# ================================================================
# Photobox — 環境変数一覧
# このファイルをコピーして .env.local に実際の値を入力してください
# cp .env.example .env.local
# ================================================================

# ----------------------------------------------------------------
# Supabase PostgreSQL
# ----------------------------------------------------------------

# Transaction Pooler URL（アプリ実行時に使用）
# Supabase Dashboard > Project Settings > Database > Connection string > URI
# Mode: Transaction  Port: 6543
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Connection URL（prisma migrate dev / db push に使用）
# Mode: Session  Port: 5432
# ※ Transaction Pooler は DDL (CREATE TABLE 等) に非対応のため migrate には使えない
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------------
# Supabase Auth / Storage
# ----------------------------------------------------------------

# Supabase Dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase Dashboard > Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase Dashboard > Project Settings > API > service_role
# ⚠ サーバー側のみ使用。NEXT_PUBLIC_ を付けない。クライアントに絶対露出しない
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ----------------------------------------------------------------
# Site URL
# ----------------------------------------------------------------

# 本番URL（Vercel デプロイ後に設定）
# Supabase Auth の Redirect URL にも登録が必要
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# ----------------------------------------------------------------
# Dev / Feature flags
# ----------------------------------------------------------------

# /dev/api-check を有効にするか（本番では false のままにすること）
# ローカル開発時のみ true にする
ENABLE_DEV_API_CHECK=false
