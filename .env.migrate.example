# ================================================================
# Photobox — prisma migrate dev 専用の環境変数ファイル
#
# Direct Connection URL を DATABASE_URL として渡す
# (Transaction Pooler は DDL / migrate 非対応のため Session Mode を使用)
#
# 使用方法:
#   cp .env.migrate.example .env.migrate
#   .env.migrate に実際の値を入力（実キーを書く）
#   npx dotenv -e .env.migrate -- npx prisma migrate dev --name <name>
#
# ⚠️ .env.migrate は .gitignore 管理外 — Git に commit しないこと
# ================================================================

# Direct Connection URL（Session Mode / port 5432）
# Supabase > Project Settings > Database > Connection string > Session mode
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# service_role key — legacy JWT（eyJ... で始まる長い文字列）
# ⚠️ NEXT_PUBLIC_ を付けないこと（クライアント露出禁止）
# Supabase > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
